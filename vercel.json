{
  "rewrites": [
    { "source": "/matrix", "destination": "/matrix-maker.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/*.csv",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Content-Type", "value": "text/csv" }
      ]
    }
  ]
}
